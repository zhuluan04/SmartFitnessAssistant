/* pages/profile/profile.wxss - 我的页样式 */

.page-container {
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: #F0FFF9;
}

/* 头像区 */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.avatar-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4ECDC4, #2BA89C);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 20rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 26rpx;
  color: #B2BEC3;
}

/* 统计卡片 */
.stats-row {
  display: flex;
  margin: 0 32rpx 32rpx;
  padding: 32rpx 16rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.08);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #4ECDC4;
  line-height: 1;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: #B2BEC3;
  display: block;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: #E8F5F0;
  align-self: center;
}

/* 分组标题 */
.section-title {
  font-size: 24rpx;
  color: #B2BEC3;
  padding: 0 32rpx 16rpx;
}

/* 功能菜单容器 */
.menu-card {
  margin: 0 32rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E8F5F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #2D3436;
}

.menu-arrow {
  font-size: 32rpx;
  color: #B2BEC3;
}
