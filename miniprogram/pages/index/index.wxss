/* pages/index/index.wxss - 首页样式 */

.page-container {
  padding-bottom: 40rpx;
}

.input-area {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #2D3436;
  border: none;
}

/* 图片上传区 */
.image-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200rpx;
  border: 2rpx dashed #4ECDC4;
  border-radius: 16rpx;
  margin-top: 24rpx;
  background: #F0FFF9;
}

.upload-icon {
  font-size: 48rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #636E72;
  margin-top: 8rpx;
}

/* 图片预览 */
.image-preview {
  position: relative;
  margin-top: 24rpx;
}

.preview-img {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
}

.remove-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 健身目标选择 */
.goal-group {
  display: flex;
  gap: 20rpx;
}

.goal-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 32rpx;
  font-size: 28rpx;
  background: #F0FFF9;
  color: #636E72;
  border: 2rpx solid #E8F5F0;
  transition: all 0.2s;
}

.goal-item.active {
  background: #4ECDC4;
  color: #FFFFFF;
  border-color: #4ECDC4;
}

/* 提交按钮 */
.submit-btn {
  margin: 32rpx 24rpx;
}
